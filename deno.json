{
  "tasks": {
    "dev": "deno run --watch-hmr --allow-net --allow-env --env=.env main.ts",
    "pre-commit": "deno fmt && deno check && deno lint"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "imports": {
    "@/": "./src/",
    "satori": "npm:satori@^0.19.1",
    "preact": "npm:preact"
  },
  "fmt": {
    "newLineKind": "lf",
    "semiColons": true,
    "singleQuote": false,
    "trailingCommas": "always"
  }
}
